<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="24"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="it.unicam.cs.mpgc.rpg123393.controller.VictoryController"
      style="-fx-background-color: #1a1a2e; -fx-padding: 60;">

    <Label text="⚔ VITTORIA! ⚔"
           style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-text-fill: #e0c97f;"/>

    <Label fx:id="summaryLabel"
           text="Hai sconfitto il nemico!"
           style="-fx-font-size: 18px; -fx-text-fill: #a0a0c0;"
           wrapText="true" textAlignment="CENTER"/>

    <VBox alignment="CENTER" spacing="8"
          style="-fx-background-color: #2a2a4a; -fx-padding: 20; -fx-background-radius: 12;">
        <Label fx:id="xpLabel"
               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #c77dff;"/>
        <Label fx:id="levelLabel"
               style="-fx-font-size: 14px; -fx-text-fill: #4ecca3;"/>
        <Label fx:id="statsLabel"
               style="-fx-font-size: 13px; -fx-text-fill: #a0a0c0;"/>
    </VBox>

    <Button text="⚔ Prossimo Scontro" onAction="#onNextBattle"
            prefWidth="240"
            style="-fx-background-color: #4ecca3; -fx-text-fill: #1a1a2e; -fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 12 32; -fx-background-radius: 8; -fx-cursor: hand;"/>

    <Button text="↩ Menu Principale" onAction="#onMainMenu"
            prefWidth="240"
            style="-fx-background-color: transparent; -fx-text-fill: #a0a0c0; -fx-font-size: 13px; -fx-border-color: #a0a0c0; -fx-border-radius: 8; -fx-padding: 8 24; -fx-cursor: hand;"/>

</VBox>
