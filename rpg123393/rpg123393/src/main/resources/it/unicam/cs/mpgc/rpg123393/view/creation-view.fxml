<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="30.0" style="-fx-background-color: #1a1a1a;" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.unicam.cs.mpgc.rpg123393.controller.CreationController">
    <padding><Insets bottom="40" left="40" right="40" top="40"/></padding>

    <Label text="Scegli la tua Classe" style="-fx-text-fill: #deff9a; -fx-font-size: 32px; -fx-font-weight: bold;"/>

    <HBox alignment="CENTER" spacing="10">
        <Label text="Nome Giocatore:" style="-fx-text-fill: white; -fx-font-size: 16px;"/>
        <TextField fx:id="nameField" promptText="Es: Artù..." />
    </HBox>

    <HBox alignment="CENTER" spacing="30.0">

        <VBox alignment="CENTER" spacing="10.0" style="-fx-background-color: #2a2a2a; -fx-padding: 20; -fx-background-radius: 10; -fx-border-color: #aaa; -fx-border-radius: 10; -fx-border-width: 2;">
            <Label text="GUERRIERO" style="-fx-text-fill: #aaaaaa; -fx-font-size: 20px; -fx-font-weight: bold;"/>
            <ImageView fitHeight="120.0" fitWidth="120.0" preserveRatio="true">
                <image><Image url="@/images/tank.jpg" /></image>
            </ImageView>
            <Label text="VIT: 8 | FOR: 3" style="-fx-text-fill: white;"/>
            <Label text="Difesa impenetrabile" style="-fx-text-fill: #aaaaaa; -fx-font-size: 12px;"/>
            <Button text="SELEZIONA" onAction="#selectWarrior" style="-fx-background-color: #aaaaaa; -fx-text-fill: black; -fx-font-weight: bold;"/>
        </VBox>

        <VBox alignment="CENTER" spacing="10.0" style="-fx-background-color: #2a2a2a; -fx-padding: 20; -fx-background-radius: 10; -fx-border-color: #3399ff; -fx-border-radius: 10; -fx-border-width: 2;">
            <Label text="MAGO" style="-fx-text-fill: #3399ff; -fx-font-size: 20px; -fx-font-weight: bold;"/>
            <ImageView fitHeight="120.0" fitWidth="120.0" preserveRatio="true">
                <image><Image url="@/images/mago.jpg" /></image>
            </ImageView>
            <Label text="VIT: 3 | FOR: 8" style="-fx-text-fill: white;"/>
            <Label text="Pochi HP, alto Mana" style="-fx-text-fill: #aaaaaa; -fx-font-size: 12px;"/>
            <Button text="SELEZIONA" onAction="#selectMage" style="-fx-background-color: #3399ff; -fx-text-fill: white; -fx-font-weight: bold;"/>
        </VBox>

        <VBox alignment="CENTER" spacing="10.0" style="-fx-background-color: #2a2a2a; -fx-padding: 20; -fx-background-radius: 10; -fx-border-color: #ff4d4d; -fx-border-radius: 10; -fx-border-width: 2;">
            <Label text="DRAGO" style="-fx-text-fill: #ff4d4d; -fx-font-size: 20px; -fx-font-weight: bold;"/>
            <ImageView fitHeight="120.0" fitWidth="120.0" preserveRatio="true">
                <image><Image url="@/images/dragon.jpg" /></image>
            </ImageView>
            <Label text="VIT: 6 | FOR: 6" style="-fx-text-fill: white;"/>
            <Label text="Forte e Bilanciato" style="-fx-text-fill: #aaaaaa; -fx-font-size: 12px;"/>
            <Button text="SELEZIONA" onAction="#selectDragon" style="-fx-background-color: #ff4d4d; -fx-text-fill: white; -fx-font-weight: bold;"/>
        </VBox>

    </HBox>
</VBox>