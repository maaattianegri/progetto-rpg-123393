<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" spacing="15.0" style="-fx-background-image: url('/images/arena_bg.jpg'); -fx-background-size: cover; -fx-background-position: center center;" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.unicam.cs.mpgc.rpg123393.controller.HelloController">
  <padding><Insets bottom="30.0" left="60.0" right="60.0" top="40.0" /></padding>

  <HBox alignment="TOP_CENTER">

    <VBox alignment="CENTER" spacing="10.0">
      <HBox alignment="CENTER" spacing="10.0">
        <Label fx:id="playerStatsLabel" style="-fx-text-fill: #4dff4d; -fx-font-weight: bold; -fx-font-size: 24px; -fx-effect: dropshadow(gaussian, black, 8, 0.8, 0, 0);" text="Giocatore HP" />
        <ImageView fitHeight="32.0" fitWidth="32.0" preserveRatio="true">
          <image><Image url="@/images/mana.jpg" /></image>
        </ImageView>
      </HBox>
      <ImageView fx:id="playerImage" fitHeight="250.0" fitWidth="250.0" preserveRatio="true" />
      <Label fx:id="playerBlockLabel" style="-fx-text-fill: #3399ff; -fx-font-size: 18px; -fx-font-weight: bold; -fx-effect: dropshadow(gaussian, black, 8, 0.8, 0, 0);" text="Scudo: 0" />
    </VBox>

    <Region HBox.hgrow="ALWAYS" />

    <VBox alignment="CENTER" spacing="10.0">
      <Label fx:id="enemyIntentLabel" style="-fx-text-fill: #ffaa00; -fx-font-size: 20px; -fx-font-weight: bold; -fx-effect: dropshadow(gaussian, black, 8, 0.8, 0, 0);" text="Intento Nemico: ?" />
      <ImageView fx:id="enemyImage" fitHeight="250.0" fitWidth="250.0" preserveRatio="true">
        <image><Image url="@/images/goblin.jpg" /></image>
      </ImageView>
      <Label fx:id="enemyStatsLabel" style="-fx-text-fill: #ff4d4d; -fx-font-weight: bold; -fx-font-size: 24px; -fx-effect: dropshadow(gaussian, black, 8, 0.8, 0, 0);" text="Nemico HP" />
    </VBox>
  </HBox>

  <Region VBox.vgrow="ALWAYS" />

  <HBox alignment="CENTER" spacing="40.0">
    <Button fx:id="cardBtn0" onAction="#onCard0Click" prefHeight="280.0" prefWidth="200.0" style="-fx-background-color: transparent; -fx-cursor: hand;" />
    <Button fx:id="cardBtn1" onAction="#onCard1Click" prefHeight="280.0" prefWidth="200.0" style="-fx-background-color: transparent; -fx-cursor: hand;" />
    <Button fx:id="cardBtn2" onAction="#onCard2Click" prefHeight="280.0" prefWidth="200.0" style="-fx-background-color: transparent; -fx-cursor: hand;" />
  </HBox>

  <Button onAction="#onEndTurnClick" style="-fx-background-color: #ff3333; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 18px; -fx-padding: 10 40;" text="FINE TURNO" />

  <TextArea fx:id="consoleArea" editable="false" prefHeight="100.0" prefWidth="800.0" style="-fx-control-inner-background: #0a0a0a; -fx-text-fill: #00ff00; -fx-font-size: 14px;" wrapText="true" />
</VBox>