<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox alignment="CENTER" spacing="28"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="it.unicam.cs.mpgc.rpg123393.controller.GameOverController"
      style="-fx-background-color: #0d0d1a; -fx-padding: 60;">

    <!-- Titolo -->
    <Label text="GAME OVER"
           style="-fx-font-size: 52px; -fx-font-weight: bold; -fx-text-fill: #e63946;
                  -fx-effect: dropshadow(gaussian, #e63946, 24, 0.5, 0, 0);"/>

    <!-- Sottotitolo dinamico -->
    <Label fx:id="defeatLabel" text="Sei caduto in battaglia..."
           style="-fx-font-size: 18px; -fx-text-fill: #c8c8e0;" wrapText="true" textAlignment="CENTER"/>

    <!-- Epilogo narrativo basato sul nemico -->
    <Label fx:id="epilogueLabel" text=""
           style="-fx-font-size: 14px; -fx-text-fill: #8a4a4a; -fx-font-style: italic;"
           wrapText="true" textAlignment="CENTER" maxWidth="480"/>

    <!-- Griglia statistiche -->
    <VBox alignment="CENTER" spacing="0"
          style="-fx-background-color: #1a0d0d; -fx-background-radius: 14;
                 -fx-border-color: #4a1a1a; -fx-border-radius: 14; -fx-border-width: 1;
                 -fx-padding: 0; -fx-max-width: 480;">

        <!-- Header -->
        <HBox alignment="CENTER" spacing="0"
              style="-fx-background-color: #2a1010; -fx-background-radius: 14 14 0 0; -fx-padding: 10 0;">
            <Label text="HP AL MOMENTO" style="-fx-text-fill: #8a6060; -fx-font-size: 11px; -fx-font-weight: bold; -fx-pref-width: 160; -fx-alignment: CENTER;"/>
            <Label text="UCCISO DA" style="-fx-text-fill: #8a6060; -fx-font-size: 11px; -fx-font-weight: bold; -fx-pref-width: 160; -fx-alignment: CENTER;"/>
            <Label text="LIVELLO RAGGIUNTO" style="-fx-text-fill: #8a6060; -fx-font-size: 11px; -fx-font-weight: bold; -fx-pref-width: 160; -fx-alignment: CENTER;"/>
        </HBox>

        <Separator style="-fx-background-color: #4a1a1a;"/>

        <!-- Valori -->
        <HBox alignment="CENTER" spacing="0" style="-fx-padding: 18 0;">
            <Label fx:id="hpStatLabel" text="—"
                   style="-fx-text-fill: #e63946; -fx-font-size: 22px; -fx-font-weight: bold;
                          -fx-pref-width: 160; -fx-alignment: CENTER;"/>
            <Label fx:id="enemyStatLabel" text="—"
                   style="-fx-text-fill: #ff6b6b; -fx-font-size: 18px; -fx-font-weight: bold;
                          -fx-pref-width: 160; -fx-alignment: CENTER; -fx-wrap-text: true;"/>
            <Label fx:id="levelStatLabel" text="—"
                   style="-fx-text-fill: #c77dff; -fx-font-size: 22px; -fx-font-weight: bold;
                          -fx-pref-width: 160; -fx-alignment: CENTER;"/>
        </HBox>

    </VBox>

    <!-- Bottoni -->
    <VBox alignment="CENTER" spacing="12" style="-fx-padding: 8 0 0 0;">
        <Button text="Ricomincia" onAction="#onRestart"
                prefWidth="280"
                style="-fx-background-color: #e63946; -fx-text-fill: white;
                       -fx-font-size: 16px; -fx-font-weight: bold;
                       -fx-padding: 14 32; -fx-background-radius: 10; -fx-cursor: hand;
                       -fx-effect: dropshadow(gaussian, #e63946, 12, 0.3, 0, 0);"/>
        <Button text="Menu Principale" onAction="#onMainMenu"
                prefWidth="280"
                style="-fx-background-color: transparent; -fx-text-fill: #6a4a4a;
                       -fx-font-size: 13px; -fx-border-color: #4a2a2a;
                       -fx-border-radius: 10; -fx-padding: 10 24; -fx-cursor: hand;"/>
    </VBox>

</VBox>
