<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="it.unicam.cs.mpgc.rpg123393.controller.MapController"
      spacing="0"
      style="-fx-background-color: #0d0d1e;">

    <!-- Header -->
    <VBox alignment="CENTER" spacing="4"
          style="-fx-padding: 24 32 12 32; -fx-background-color: #0d0d1e;">
        <Label text="&#x1F5FA; Mappa del Dungeon"
               style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #c4b5fd;"/>
        <HBox alignment="CENTER" spacing="32">
            <Label fx:id="playerHpLabel" text="HP: —"
                   style="-fx-font-size: 13px; -fx-text-fill: #4ade80;"/>
            <Label fx:id="playerGoldLabel" text="Oro: —"
                   style="-fx-font-size: 13px; -fx-text-fill: #fbbf24;"/>
            <Label fx:id="playerLevelLabel" text="Lv. —"
                   style="-fx-font-size: 13px; -fx-text-fill: #93c5fd;"/>
            <Label fx:id="progressLabel" text=""
                   style="-fx-font-size: 13px; -fx-text-fill: #9ca3af;"/>
        </HBox>
    </VBox>

    <!-- Legenda -->
    <HBox fx:id="legendBox" alignment="CENTER" spacing="18"
          style="-fx-padding: 0 32 10 32; -fx-background-color: #0d0d1e;"/>

    <!-- Canvas mappa (scroll orizzontale) -->
    <ScrollPane fitToHeight="false" fitToWidth="false"
                hbarPolicy="AS_NEEDED" vbarPolicy="NEVER"
                style="-fx-background: #0d0d1e; -fx-background-color: #0d0d1e;
                       -fx-border-color: transparent;"
                VBox.vgrow="ALWAYS">
        <Pane fx:id="mapPane"
              style="-fx-background-color: #0d0d1e;"
              minHeight="420" minWidth="900"/>
    </ScrollPane>

    <!-- Label nodo selezionato (tooltip testuale) -->
    <HBox alignment="CENTER" style="-fx-padding: 10 32 20 32; -fx-background-color: #0d0d1e;">
        <Label fx:id="selectedNodeLabel" text="Clicca un nodo raggiungibile per avanzare"
               style="-fx-font-size: 13px; -fx-text-fill: #9ca3af;" wrapText="true"
               maxWidth="700" alignment="CENTER"/>
    </HBox>

</VBox>
