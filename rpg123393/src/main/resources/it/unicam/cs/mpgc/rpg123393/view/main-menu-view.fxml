<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="it.unicam.cs.mpgc.rpg123393.controller.MainMenuController"
      style="-fx-background-color: #1a1a2e; -fx-padding: 60;">

    <Label text="&#x2694; ARENA MASTER &#x2694;"
           style="-fx-font-size: 52px; -fx-font-weight: bold; -fx-text-fill: #e0c97f;
                  -fx-effect: dropshadow(gaussian, #e0c97f, 18, 0.35, 0, 0);"/>

    <Label text="La Forgia degli Eroi"
           style="-fx-font-size: 18px; -fx-text-fill: #6a6a9a;"/>

    <Label text="" style="-fx-pref-height: 20;"/>

    <Button text="Nuova Partita" onAction="#onNewGame"
            prefWidth="300"
            style="-fx-background-color: #4ecca3; -fx-text-fill: #1a1a2e;
                   -fx-font-size: 18px; -fx-font-weight: bold;
                   -fx-padding: 16 32; -fx-background-radius: 10; -fx-cursor: hand;
                   -fx-effect: dropshadow(gaussian, #4ecca3, 14, 0.3, 0, 0);"/>

    <VBox alignment="CENTER" spacing="5">
        <Button fx:id="continueBtn" text="Continua" onAction="#onContinue"
                prefWidth="300"
                style="-fx-background-color: #4ecca3; -fx-text-fill: #1a1a2e;
                       -fx-font-size: 18px; -fx-font-weight: bold;
                       -fx-padding: 16 32; -fx-background-radius: 10; -fx-cursor: hand;
                       -fx-effect: dropshadow(gaussian, #4ecca3, 14, 0.3, 0, 0);"/>
        <Label fx:id="saveInfoLabel" text=""
               style="-fx-font-size: 12px; -fx-text-fill: #5a5a7a; -fx-font-style: italic;"/>
    </VBox>

    <Button text="&#x1F4D6; Collezione" onAction="#onCollection"
            prefWidth="300"
            style="-fx-background-color: transparent; -fx-text-fill: #e0c97f;
                   -fx-font-size: 18px; -fx-font-weight: bold;
                   -fx-border-color: #6a5a20; -fx-border-radius: 10;
                   -fx-padding: 16 32; -fx-cursor: hand;"/>

    <Button text="&#x1F3C6; Achievement" onAction="#onAchievements"
            prefWidth="300"
            style="-fx-background-color: transparent; -fx-text-fill: #e0c97f;
                   -fx-font-size: 18px; -fx-font-weight: bold;
                   -fx-border-color: #6a5a20; -fx-border-radius: 10;
                   -fx-padding: 16 32; -fx-cursor: hand;"/>

    <Label text="" style="-fx-pref-height: 10;"/>

    <Button text="Esci" onAction="#onExit"
            prefWidth="300"
            style="-fx-background-color: transparent; -fx-text-fill: #8a3030;
                   -fx-font-size: 18px; -fx-font-weight: bold;
                   -fx-padding: 16 32; -fx-background-radius: 10;
                   -fx-cursor: hand; -fx-border-color: #5a2020; -fx-border-radius: 10;
                   -fx-border-width: 1;"/>

</VBox>
