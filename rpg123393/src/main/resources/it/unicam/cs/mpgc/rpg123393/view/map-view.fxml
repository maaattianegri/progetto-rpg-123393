<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="it.unicam.cs.mpgc.rpg123393.controller.MapController"
      spacing="0"
      style="-fx-background-color: #0d0d1e;">

    <!-- Header -->
    <VBox alignment="CENTER" spacing="4"
          style="-fx-padding: 24 32 12 32; -fx-background-color: #0d0d1e;">
        <Label text="&#x1F5FA; Mappa del Dungeon"
               style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #c4b5fd;"/>
        <HBox alignment="CENTER" spacing="32">
            <Label fx:id="playerHpLabel" text="HP: —"
                   style="-fx-font-size: 13px; -fx-text-fill: #4ade80;"/>
            <Label fx:id="playerGoldLabel" text="Oro: —"
                   style="-fx-font-size: 13px; -fx-text-fill: #fbbf24;"/>
            <Label fx:id="playerLevelLabel" text="Lv. —"
                   style="-fx-font-size: 13px; -fx-text-fill: #93c5fd;"/>
            <Label fx:id="progressLabel" text=""
                   style="-fx-font-size: 13px; -fx-text-fill: #9ca3af;"/>
        </HBox>
    </VBox>

    <!-- Legenda nodi -->
    <HBox fx:id="legendBox" alignment="CENTER" spacing="18"
          style="-fx-padding: 0 32 10 32; -fx-background-color: #0d0d1e;"/>

    <!-- Mappa navigabile: ScrollPane senza scrollbar visibili -->
    <ScrollPane fx:id="mapScroll"
                fitToHeight="false"
                fitToWidth="false"
                pannable="false"
                hbarPolicy="NEVER"
                vbarPolicy="NEVER"
                VBox.vgrow="ALWAYS"
                style="-fx-background: #0d0d1e; -fx-background-color: #0d0d1e;">
        <content>
            <Pane fx:id="mapPane"
                  style="-fx-background-color: #0d0d1e;"/>
        </content>
    </ScrollPane>

    <!-- Label stato -->
    <HBox alignment="CENTER" style="-fx-padding: 10 32 8 32; -fx-background-color: #0d0d1e;">
        <Label fx:id="selectedNodeLabel"
               text="Trascina per muoverti &#x2022; Rotella per zoomare &#x2022; Clicca un nodo raggiungibile per avanzare"
               style="-fx-font-size: 13px; -fx-text-fill: #9ca3af;"
               wrapText="true" maxWidth="900" alignment="CENTER"/>
    </HBox>

    <!-- Barra inferiore: legenda controlli + tasto salva -->
    <HBox fx:id="controlsLegendBox" alignment="CENTER" spacing="16"
          style="-fx-padding: 0 20 18 20; -fx-background-color: #0d0d1e;">
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="saveMenuBtn"
                text="&#x1F4BE; Salva e torna al menu"
                onAction="#onSaveAndMenu"
                style="-fx-background-color: #1e293b;
                       -fx-text-fill: #94a3b8;
                       -fx-font-size: 12px;
                       -fx-padding: 6 14;
                       -fx-background-radius: 6;
                       -fx-border-color: #334155;
                       -fx-border-radius: 6;
                       -fx-border-width: 1;
                       -fx-cursor: hand;"/>
    </HBox>

</VBox>
