<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="it.unicam.cs.mpgc.rpg123393.controller.RunVictoryController"
           style="-fx-background-color: #0d0d1a;">

    <VBox alignment="CENTER" spacing="24" style="-fx-padding: 60 80 60 80;">

        <!-- Titolo -->
        <Label fx:id="titleLabel"
               text="✦ VITTORIA ✦"
               style="-fx-font-size: 52px;
                      -fx-font-weight: bold;
                      -fx-text-fill: #ffd700;
                      -fx-effect: dropshadow(gaussian, #ffd700, 30, 0.6, 0, 0);" />

        <!-- Sottotitolo -->
        <Label fx:id="subtitleLabel"
               text="La tua leggenda è stata scritta."
               style="-fx-font-size: 18px;
                      -fx-text-fill: #c0b090;
                      -fx-font-style: italic;" />

        <!-- Epilogo narrativo -->
        <Label fx:id="epilogueLabel"
               wrapText="true"
               maxWidth="700"
               alignment="CENTER"
               style="-fx-font-size: 14px;
                      -fx-text-fill: #a0a8c0;
                      -fx-padding: 0 0 12 0;" />

        <!-- Separatore -->
        <Separator style="-fx-background-color: #3a3a5a;" maxWidth="600" />

        <!-- Pannello statistiche -->
        <VBox alignment="CENTER" spacing="10"
              style="-fx-background-color: #16162a;
                     -fx-background-radius: 12;
                     -fx-border-color: #3a3a6a;
                     -fx-border-radius: 12;
                     -fx-border-width: 1;
                     -fx-padding: 24 48 24 48;">

            <Label text="— STATISTICHE RUN —"
                   style="-fx-font-size: 13px;
                          -fx-text-fill: #6060a0;
                          -fx-font-weight: bold;
                          -fx-padding: 0 0 8 0;" />

            <Label fx:id="playerStatLabel"
                   style="-fx-font-size: 15px; -fx-text-fill: #e0e0ff;" />
            <Label fx:id="levelStatLabel"
                   style="-fx-font-size: 15px; -fx-text-fill: #a78bfa;" />
            <Label fx:id="hpStatLabel"
                   style="-fx-font-size: 15px; -fx-text-fill: #4ade80;" />
            <Label fx:id="nodesStatLabel"
                   style="-fx-font-size: 15px; -fx-text-fill: #60a5fa;" />
            <Label fx:id="goldStatLabel"
                   style="-fx-font-size: 15px; -fx-text-fill: #fbbf24;" />
            <Label fx:id="cardsStatLabel"
                   style="-fx-font-size: 15px; -fx-text-fill: #f472b6;" />
            <Label fx:id="upgradesStatLabel"
                   style="-fx-font-size: 15px; -fx-text-fill: #34d399;" />
        </VBox>

        <!-- Separatore -->
        <Separator style="-fx-background-color: #3a3a5a;" maxWidth="600" />

        <!-- Pulsante -->
        <Button fx:id="mainMenuButton"
                text="↩  Torna al Menu Principale"
                onAction="#onMainMenu"
                style="-fx-background-color: #ffd700;
                       -fx-text-fill: #0d0d1a;
                       -fx-font-size: 16px;
                       -fx-font-weight: bold;
                       -fx-background-radius: 8;
                       -fx-padding: 12 36 12 36;
                       -fx-cursor: hand;
                       -fx-effect: dropshadow(gaussian, #ffd700, 12, 0.4, 0, 0);" />

    </VBox>
</StackPane>
