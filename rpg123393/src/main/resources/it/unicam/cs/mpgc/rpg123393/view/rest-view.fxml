<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="rootPane" alignment="CENTER" spacing="24"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="it.unicam.cs.mpgc.rpg123393.controller.RestController"
      style="-fx-background-color: #1a1a2e; -fx-padding: 60;">

    <Label text="&#x1F525; Fal&#xF2; di Riposo"
           style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #e0c97f;
                  -fx-effect: dropshadow(gaussian, #e0c97f, 14, 0.3, 0, 0);"/>

    <Label fx:id="hpLabel" text=""
           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #4ecca3;
                  -fx-effect: dropshadow(gaussian, #4ecca3, 8, 0.2, 0, 0);"/>

    <VBox alignment="CENTER" spacing="14" style="-fx-padding: 20 0;">
        <Button text="&#x2764; Riposa (recupera HP)" onAction="#onRest"
                prefWidth="340"
                style="-fx-background-color: #4ecca3; -fx-text-fill: #1a1a2e;
                       -fx-font-size: 16px; -fx-font-weight: bold;
                       -fx-padding: 16 32; -fx-background-radius: 10; -fx-cursor: hand;"/>

        <Button text="&#x1F4DA; Forgia (potenzia una carta)" onAction="#onForge"
                prefWidth="340"
                style="-fx-background-color: #e0c97f; -fx-text-fill: #1a1a2e;
                       -fx-font-size: 16px; -fx-font-weight: bold;
                       -fx-padding: 16 32; -fx-background-radius: 10; -fx-cursor: hand;"/>
    </VBox>

    <Label fx:id="resultLabel" text=""
           style="-fx-font-size: 14px; -fx-text-fill: #a0a0c0; -fx-font-style: italic;"/>

    <Button text="&#x27A1; Continua" onAction="#onContinue"
            prefWidth="280"
            style="-fx-background-color: transparent; -fx-text-fill: #6a6a9a;
                   -fx-font-size: 14px; -fx-border-color: #3a3a6a;
                   -fx-border-radius: 8; -fx-padding: 12 24; -fx-cursor: hand;"/>

</VBox>
