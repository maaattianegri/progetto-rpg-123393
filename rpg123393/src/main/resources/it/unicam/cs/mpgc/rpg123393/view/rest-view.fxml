<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="it.unicam.cs.mpgc.rpg123393.controller.RestController"
      alignment="CENTER"
      spacing="28"
      style="-fx-background-color: #0d0d1e; -fx-padding: 60;">

    <Label fx:id="titleLabel"
           text="🔥 Nodo di Riposo"
           style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #4ade80;"/>

    <Label text="Sei arrivato in un luogo tranquillo. Cosa vuoi fare?"
           style="-fx-font-size: 15px; -fx-text-fill: #9ca3af;"
           wrapText="true" maxWidth="480" alignment="CENTER"/>

    <Label fx:id="hpLabel"
           text="HP: —"
           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #4ade80;"/>

    <!-- Scelte -->
    <HBox alignment="CENTER" spacing="32">
        <padding><Insets top="12"/></padding>

        <!-- Riposa -->
        <VBox alignment="CENTER" spacing="14"
              style="-fx-background-color: #1e1e3a; -fx-background-radius: 14;
                     -fx-border-color: #4ade80; -fx-border-radius: 14; -fx-border-width: 2;
                     -fx-padding: 28; -fx-pref-width: 220;
                     -fx-effect: dropshadow(gaussian, #4ade80, 10, 0.2, 0, 0);">
            <Label text="🛡" style="-fx-font-size: 48px;"/>
            <Label text="Riposa"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="Recupera il 30% degli HP massimi."
                   style="-fx-font-size: 12px; -fx-text-fill: #a0a0c0;"
                   wrapText="true" maxWidth="180" alignment="CENTER"/>
            <Button fx:id="healBtn"
                    text="Riposati"
                    onAction="#onHeal"
                    style="-fx-background-color: #4ade80; -fx-text-fill: #1a1a2e;
                           -fx-font-weight: bold; -fx-padding: 10 28;
                           -fx-background-radius: 8; -fx-cursor: hand;"/>
        </VBox>

        <!-- Potenzia -->
        <VBox alignment="CENTER" spacing="14"
              style="-fx-background-color: #1e1e3a; -fx-background-radius: 14;
                     -fx-border-color: #f97316; -fx-border-radius: 14; -fx-border-width: 2;
                     -fx-padding: 28; -fx-pref-width: 220;
                     -fx-effect: dropshadow(gaussian, #f97316, 10, 0.2, 0, 0);">
            <Label text="⬆" style="-fx-font-size: 48px; -fx-text-fill: #f97316;"/>
            <Label text="Potenzia una carta"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="Migliora una carta del tuo mazzo."
                   style="-fx-font-size: 12px; -fx-text-fill: #a0a0c0;"
                   wrapText="true" maxWidth="180" alignment="CENTER"/>
            <Button fx:id="upgradeBtn"
                    text="Potenzia"
                    onAction="#onUpgrade"
                    style="-fx-background-color: #f97316; -fx-text-fill: #1a1a2e;
                           -fx-font-weight: bold; -fx-padding: 10 28;
                           -fx-background-radius: 8; -fx-cursor: hand;"/>
        </VBox>
    </HBox>

    <!-- Feedback dopo scelta -->
    <Label fx:id="feedbackLabel"
           text=""
           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #4ade80;"/>

    <!-- Continua (appare dopo la scelta) -->
    <Button fx:id="continueBtn"
            text="Continua →"
            onAction="#onContinue"
            visible="false" managed="false"
            style="-fx-background-color: #6d28d9; -fx-text-fill: white;
                   -fx-font-size: 15px; -fx-font-weight: bold;
                   -fx-padding: 12 36; -fx-background-radius: 10; -fx-cursor: hand;
                   -fx-effect: dropshadow(gaussian, #6d28d9, 12, 0.3, 0, 0);"/>

</VBox>
