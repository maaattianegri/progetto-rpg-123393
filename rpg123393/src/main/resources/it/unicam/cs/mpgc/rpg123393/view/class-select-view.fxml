<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="it.unicam.cs.mpgc.rpg123393.controller.ClassSelectController"
    style="-fx-background-color: #1a1a2e;">

  <!-- TOP: titolo e campo nome -->
  <VBox alignment="CENTER" spacing="12"
        style="-fx-padding: 36 0 24 0;">
    <Label text="Scegli il tuo Eroe"
           style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #e0c97f;"/>
    <Label text="Ogni classe ha carte e abilit&#224; uniche"
           style="-fx-font-size: 14px; -fx-text-fill: #6a6a9a;"/>
    <VBox alignment="CENTER" spacing="6">
      <Label text="Nome del tuo Eroe:"
             style="-fx-font-size: 13px; -fx-text-fill: #cccccc;"/>
      <TextField fx:id="nameField" promptText="Inserisci il nome..." maxWidth="300"
                 style="-fx-font-size: 14px; -fx-background-color: #2a2a4a;
                        -fx-text-fill: white; -fx-prompt-text-fill: #666688;
                        -fx-padding: 10; -fx-background-radius: 8;"/>
    </VBox>
    <Label text="Scegli la tua Classe:"
           style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #cccccc;"/>
  </VBox>

  <!-- CENTER: 5 card affiancate, vgrow=ALWAYS -->
  <HBox alignment="CENTER" spacing="0"
        style="-fx-padding: 0 24;"
        VBox.vgrow="ALWAYS">

    <!-- CAVALIERE -->
    <StackPane HBox.hgrow="ALWAYS" style="-fx-padding: 10;">
      <VBox fx:id="cardWarrior" spacing="0"
            style="-fx-background-color: #1e1218; -fx-padding: 24 20;
                   -fx-background-radius: 16; -fx-border-color: #e74c3c;
                   -fx-border-radius: 16; -fx-border-width: 2; -fx-cursor: hand;"
            minWidth="200" minHeight="440">
        <VBox alignment="CENTER" VBox.vgrow="ALWAYS">
          <ImageView fx:id="imgWarrior"
                     fitWidth="160" fitHeight="160"
                     preserveRatio="true"
                     style="-fx-effect: dropshadow(gaussian, #e74c3c, 12, 0.4, 0, 0);"/>
        </VBox>
        <VBox alignment="CENTER" spacing="6">
          <Label text="CAVALIERE"
                 style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;"/>
          <Label text="Vigore 8 &#x2022; Arcano 3"
                 style="-fx-font-size: 12px; -fx-text-fill: #a0a0c0;"/>
          <Label text="Alto danno fisico,"
                 style="-fx-font-size: 11px; -fx-text-fill: #888; -fx-text-alignment: center;"/>
          <Label text="bassa resistenza magica."
                 style="-fx-font-size: 11px; -fx-text-fill: #888; -fx-text-alignment: center;"/>
          <Label text="&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;"
                 style="-fx-text-fill: #3a3a5a; -fx-font-size: 10px;"/>
          <Label text="Colpo di Spada x2"
                 style="-fx-font-size: 10px; -fx-text-fill: #e74c3c;"/>
          <Label text="Scudo di Legno"
                 style="-fx-font-size: 10px; -fx-text-fill: #e74c3c;"/>
          <Label text="Colpo Devastante x2"
                 style="-fx-font-size: 10px; -fx-text-fill: #e74c3c;"/>
          <Label text="&#x25aa; Accesso al Vuoto"
                 style="-fx-font-size: 11px; -fx-text-fill: #9333ea; -fx-font-weight: bold;">
            <VBox.margin><Insets top="8"/></VBox.margin>
          </Label>
        </VBox>
        <Region VBox.vgrow="ALWAYS"/>
        <Button text="Scegli" onAction="#selectWarrior" maxWidth="Infinity"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-padding: 12 0;
                       -fx-background-radius: 8; -fx-font-size: 13px;"/>
      </VBox>
    </StackPane>

    <!-- MAGO -->
    <StackPane HBox.hgrow="ALWAYS" style="-fx-padding: 10;">
      <VBox fx:id="cardMage" spacing="0"
            style="-fx-background-color: #16101e; -fx-padding: 24 20;
                   -fx-background-radius: 16; -fx-border-color: #9b59b6;
                   -fx-border-radius: 16; -fx-border-width: 2; -fx-cursor: hand;"
            minWidth="200" minHeight="440">
        <VBox alignment="CENTER" VBox.vgrow="ALWAYS">
          <ImageView fx:id="imgMage"
                     fitWidth="160" fitHeight="160"
                     preserveRatio="true"
                     style="-fx-effect: dropshadow(gaussian, #9b59b6, 12, 0.4, 0, 0);"/>
        </VBox>
        <VBox alignment="CENTER" spacing="6">
          <Label text="MAGO"
                 style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #9b59b6;"/>
          <Label text="Vigore 3 &#x2022; Arcano 8"
                 style="-fx-font-size: 12px; -fx-text-fill: #a0a0c0;"/>
          <Label text="Mana abbondante,"
                 style="-fx-font-size: 11px; -fx-text-fill: #888; -fx-text-alignment: center;"/>
          <Label text="fragilit&#224; in corpo a corpo."
                 style="-fx-font-size: 11px; -fx-text-fill: #888; -fx-text-alignment: center;"/>
          <Label text="&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;"
                 style="-fx-text-fill: #3a3a5a; -fx-font-size: 10px;"/>
          <Label text="Palla di Fuoco x2"
                 style="-fx-font-size: 10px; -fx-text-fill: #9b59b6;"/>
          <Label text="Scudo di Legno"
                 style="-fx-font-size: 10px; -fx-text-fill: #9b59b6;"/>
          <Label text="Tempesta Arcana x2"
                 style="-fx-font-size: 10px; -fx-text-fill: #9b59b6;"/>
        </VBox>
        <Region VBox.vgrow="ALWAYS"/>
        <Button text="Scegli" onAction="#selectMage" maxWidth="Infinity"
                style="-fx-background-color: #9b59b6; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-padding: 12 0;
                       -fx-background-radius: 8; -fx-font-size: 13px;"/>
      </VBox>
    </StackPane>

    <!-- DRACOMANTE -->
    <StackPane HBox.hgrow="ALWAYS" style="-fx-padding: 10;">
      <VBox fx:id="cardDragon" spacing="0"
            style="-fx-background-color: #1c1208; -fx-padding: 24 20;
                   -fx-background-radius: 16; -fx-border-color: #e67e22;
                   -fx-border-radius: 16; -fx-border-width: 2; -fx-cursor: hand;"
            minWidth="200" minHeight="440">
        <VBox alignment="CENTER" VBox.vgrow="ALWAYS">
          <ImageView fx:id="imgDragon"
                     fitWidth="160" fitHeight="160"
                     preserveRatio="true"
                     style="-fx-effect: dropshadow(gaussian, #e67e22, 12, 0.4, 0, 0);"/>
        </VBox>
        <VBox alignment="CENTER" spacing="6">
          <Label text="DRACOMANTE"
                 style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #e67e22;"/>
          <Label text="Vigore 6 &#x2022; Arcano 6"
                 style="-fx-font-size: 12px; -fx-text-fill: #a0a0c0;"/>
          <Label text="Perfetto equilibrio"
                 style="-fx-font-size: 11px; -fx-text-fill: #888; -fx-text-alignment: center;"/>
          <Label text="tra fisico e magico."
                 style="-fx-font-size: 11px; -fx-text-fill: #888; -fx-text-alignment: center;"/>
          <Label text="&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;"
                 style="-fx-text-fill: #3a3a5a; -fx-font-size: 10px;"/>
          <Label text="Zanna di Drago x2"
                 style="-fx-font-size: 10px; -fx-text-fill: #e67e22;"/>
          <Label text="Scudo di Legno"
                 style="-fx-font-size: 10px; -fx-text-fill: #e67e22;"/>
          <Label text="Artiglio del Drago x2"
                 style="-fx-font-size: 10px; -fx-text-fill: #e67e22;"/>
        </VBox>
        <Region VBox.vgrow="ALWAYS"/>
        <Button text="Scegli" onAction="#selectDragon" maxWidth="Infinity"
                style="-fx-background-color: #e67e22; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-padding: 12 0;
                       -fx-background-radius: 8; -fx-font-size: 13px;"/>
      </VBox>
    </StackPane>

    <!-- PALADINO -->
    <StackPane HBox.hgrow="ALWAYS" style="-fx-padding: 10;">
      <VBox fx:id="cardPaladin" spacing="0"
            style="-fx-background-color: #1c1a08; -fx-padding: 24 20;
                   -fx-background-radius: 16; -fx-border-color: #f1c40f;
                   -fx-border-radius: 16; -fx-border-width: 2; -fx-cursor: hand;"
            minWidth="200" minHeight="440">
        <VBox alignment="CENTER" VBox.vgrow="ALWAYS">
          <ImageView fx:id="imgPaladin"
                     fitWidth="160" fitHeight="160"
                     preserveRatio="true"
                     style="-fx-effect: dropshadow(gaussian, #f1c40f, 12, 0.4, 0, 0);"/>
        </VBox>
        <VBox alignment="CENTER" spacing="6">
          <Label text="PALADINO"
                 style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #f1c40f;"/>
          <Label text="Vigore 7 &#x2022; Arcano 5"
                 style="-fx-font-size: 12px; -fx-text-fill: #a0a0c0;"/>
          <Label text="Tank difensivo,"
                 style="-fx-font-size: 11px; -fx-text-fill: #888; -fx-text-alignment: center;"/>
          <Label text="eccellente resistenza."
                 style="-fx-font-size: 11px; -fx-text-fill: #888; -fx-text-alignment: center;"/>
          <Label text="&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;"
                 style="-fx-text-fill: #3a3a5a; -fx-font-size: 10px;"/>
          <Label text="Colpo di Spada"
                 style="-fx-font-size: 10px; -fx-text-fill: #f1c40f;"/>
          <Label text="Scudo di Legno x2"
                 style="-fx-font-size: 10px; -fx-text-fill: #f1c40f;"/>
          <Label text="Scudo Sacro x2"
                 style="-fx-font-size: 10px; -fx-text-fill: #f1c40f;"/>
        </VBox>
        <Region VBox.vgrow="ALWAYS"/>
        <Button text="Scegli" onAction="#selectPaladin" maxWidth="Infinity"
                style="-fx-background-color: #f1c40f; -fx-text-fill: #1a1a2e;
                       -fx-font-weight: bold; -fx-padding: 12 0;
                       -fx-background-radius: 8; -fx-font-size: 13px;"/>
      </VBox>
    </StackPane>

    <!-- ASSASSINO -->
    <StackPane HBox.hgrow="ALWAYS" style="-fx-padding: 10;">
      <VBox fx:id="cardAssassin" spacing="0"
            style="-fx-background-color: #0e1a12; -fx-padding: 24 20;
                   -fx-background-radius: 16; -fx-border-color: #27ae60;
                   -fx-border-radius: 16; -fx-border-width: 2; -fx-cursor: hand;"
            minWidth="200" minHeight="440">
        <VBox alignment="CENTER" VBox.vgrow="ALWAYS">
          <ImageView fx:id="imgAssassin"
                     fitWidth="160" fitHeight="160"
                     preserveRatio="true"
                     style="-fx-effect: dropshadow(gaussian, #27ae60, 12, 0.4, 0, 0);"/>
        </VBox>
        <VBox alignment="CENTER" spacing="6">
          <Label text="ASSASSINO"
                 style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
          <Label text="Vigore 4 &#x2022; Arcano 6"
                 style="-fx-font-size: 12px; -fx-text-fill: #a0a0c0;"/>
          <Label text="Veleno e critici,"
                 style="-fx-font-size: 11px; -fx-text-fill: #888; -fx-text-alignment: center;"/>
          <Label text="bassa resistenza diretta."
                 style="-fx-font-size: 11px; -fx-text-fill: #888; -fx-text-alignment: center;"/>
          <Label text="&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;"
                 style="-fx-text-fill: #3a3a5a; -fx-font-size: 10px;"/>
          <Label text="Lama Avvelenata x3"
                 style="-fx-font-size: 10px; -fx-text-fill: #27ae60;"/>
          <Label text="Veleno Acido"
                 style="-fx-font-size: 10px; -fx-text-fill: #27ae60;"/>
          <Label text="Scudo di Legno"
                 style="-fx-font-size: 10px; -fx-text-fill: #27ae60;"/>
        </VBox>
        <Region VBox.vgrow="ALWAYS"/>
        <Button text="Scegli" onAction="#selectAssassin" maxWidth="Infinity"
                style="-fx-background-color: #27ae60; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-padding: 12 0;
                       -fx-background-radius: 8; -fx-font-size: 13px;"/>
      </VBox>
    </StackPane>

  </HBox>

  <!-- BOTTOM: pulsante torna -->
  <VBox alignment="CENTER" style="-fx-padding: 16 0 28 0;">
    <Button text="&#x2190; Torna al Menu" onAction="#onBack"
            style="-fx-background-color: transparent; -fx-text-fill: #6a6a9a;
                   -fx-font-size: 13px; -fx-border-color: #3a3a6a;
                   -fx-border-radius: 8; -fx-padding: 8 24; -fx-cursor: hand;"/>
  </VBox>

</VBox>
