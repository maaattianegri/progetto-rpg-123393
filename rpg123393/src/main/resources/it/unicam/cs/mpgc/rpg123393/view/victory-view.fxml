<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.Region?>

<VBox alignment="CENTER" spacing="22"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="it.unicam.cs.mpgc.rpg123393.controller.VictoryController"
      style="-fx-background-color: #1a1a2e; -fx-padding: 60;">

    <!-- Titolo -->
    <Label text="VITTORIA!"
           style="-fx-font-size: 52px; -fx-font-weight: bold; -fx-text-fill: #e0c97f;
                  -fx-effect: dropshadow(gaussian, #e0c97f, 20, 0.4, 0, 0);"/>

    <!-- Sottotitolo -->
    <Label fx:id="summaryLabel" text="Hai sconfitto il nemico!"
           style="-fx-font-size: 18px; -fx-text-fill: #c8c8e0;" wrapText="true" textAlignment="CENTER"/>

    <!-- Pill XP + level up -->
    <HBox alignment="CENTER" spacing="16">
        <Label fx:id="xpLabel" text="+0 XP"
               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #c77dff;
                      -fx-background-color: #2d1f4a; -fx-padding: 8 20;
                      -fx-background-radius: 20;"/>
        <Label fx:id="levelUpBadge" text=""
               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;
                      -fx-background-color: #4ecca3; -fx-padding: 8 20;
                      -fx-background-radius: 20;" visible="false" managed="false"/>
    </HBox>

    <!-- Griglia statistiche battaglia -->
    <VBox alignment="CENTER" spacing="0"
          style="-fx-background-color: #22224a; -fx-background-radius: 14;
                 -fx-border-color: #3a3a6a; -fx-border-radius: 14; -fx-border-width: 1;
                 -fx-padding: 0; -fx-max-width: 480;">

        <HBox alignment="CENTER" spacing="0"
              style="-fx-background-color: #2a2a5a; -fx-background-radius: 14 14 0 0; -fx-padding: 10 0;">
            <Label text="HP RIMASTI" style="-fx-text-fill: #a0a0c0; -fx-font-size: 11px; -fx-font-weight: bold; -fx-pref-width: 160; -fx-alignment: CENTER;"/>
            <Label text="NEMICO" style="-fx-text-fill: #a0a0c0; -fx-font-size: 11px; -fx-font-weight: bold; -fx-pref-width: 160; -fx-alignment: CENTER;"/>
            <Label text="LIVELLO" style="-fx-text-fill: #a0a0c0; -fx-font-size: 11px; -fx-font-weight: bold; -fx-pref-width: 160; -fx-alignment: CENTER;"/>
        </HBox>

        <Separator style="-fx-background-color: #3a3a6a;"/>

        <HBox alignment="CENTER" spacing="0" style="-fx-padding: 18 0;">
            <Label fx:id="hpStatLabel" text="—"
                   style="-fx-text-fill: #4ecca3; -fx-font-size: 22px; -fx-font-weight: bold;
                          -fx-pref-width: 160; -fx-alignment: CENTER;"/>
            <Label fx:id="enemyStatLabel" text="—"
                   style="-fx-text-fill: #ff9a3c; -fx-font-size: 18px; -fx-font-weight: bold;
                          -fx-pref-width: 160; -fx-alignment: CENTER; -fx-wrap-text: true;"/>
            <Label fx:id="levelStatLabel" text="—"
                   style="-fx-text-fill: #c77dff; -fx-font-size: 22px; -fx-font-weight: bold;
                          -fx-pref-width: 160; -fx-alignment: CENTER;"/>
        </HBox>
    </VBox>

    <!-- XP verso prossimo livello -->
    <Label fx:id="xpProgressLabel" text=""
           style="-fx-font-size: 13px; -fx-text-fill: #6a6a9a;"/>

    <!-- Pannello statistiche run completa (visibile solo dopo ultimo boss) -->
    <VBox alignment="CENTER" spacing="0"
          style="-fx-background-color: #12101a; -fx-background-radius: 14;
                 -fx-border-color: #3a2a5a; -fx-border-radius: 14; -fx-border-width: 1;
                 -fx-padding: 0; -fx-max-width: 480;">

        <HBox alignment="CENTER" spacing="0"
              style="-fx-background-color: #1e1830; -fx-background-radius: 14 14 0 0; -fx-padding: 10 0;">
            <Label text="🏆  STATISTICHE RUN COMPLETA"
                   style="-fx-text-fill: #e0c97f; -fx-font-size: 12px; -fx-font-weight: bold; -fx-alignment: CENTER;"/>
        </HBox>

        <Separator style="-fx-background-color: #3a2a5a;"/>

        <VBox spacing="10" style="-fx-padding: 18 32;">
            <Label fx:id="nodesStatLabel" text=""
                   style="-fx-text-fill: #a0a0c0; -fx-font-size: 14px;" visible="false" managed="false"/>
            <Label fx:id="goldStatLabel" text=""
                   style="-fx-text-fill: #fbbf24; -fx-font-size: 14px;" visible="false" managed="false"/>
            <Label fx:id="cardsStatLabel" text=""
                   style="-fx-text-fill: #60a5fa; -fx-font-size: 14px;" visible="false" managed="false"/>
            <Label fx:id="upgradesStatLabel" text=""
                   style="-fx-text-fill: #c084fc; -fx-font-size: 14px;" visible="false" managed="false"/>
        </VBox>
    </VBox>

    <!-- Bottoni -->
    <VBox alignment="CENTER" spacing="12" style="-fx-padding: 8 0 0 0;">
        <Button text="Prossimo Scontro" onAction="#onNextBattle"
                prefWidth="280"
                style="-fx-background-color: #4ecca3; -fx-text-fill: #1a1a2e;
                       -fx-font-size: 16px; -fx-font-weight: bold;
                       -fx-padding: 14 32; -fx-background-radius: 10; -fx-cursor: hand;
                       -fx-effect: dropshadow(gaussian, #4ecca3, 12, 0.3, 0, 0);"/>
        <Button text="Menu Principale" onAction="#onMainMenu"
                prefWidth="280"
                style="-fx-background-color: transparent; -fx-text-fill: #6a6a9a;
                       -fx-font-size: 13px; -fx-border-color: #3a3a6a;
                       -fx-border-radius: 10; -fx-padding: 10 24; -fx-cursor: hand;"/>
    </VBox>

</VBox>
