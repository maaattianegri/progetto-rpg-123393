<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox alignment="CENTER" spacing="32"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="it.unicam.cs.mpgc.rpg123393.controller.CardRewardController"
      style="-fx-background-color: #1a1a2e; -fx-padding: 60;">

    <Label text="Scegli una Carta"
           style="-fx-font-size: 38px; -fx-font-weight: bold; -fx-text-fill: #e0c97f;
                  -fx-effect: dropshadow(gaussian, #e0c97f, 16, 0.35, 0, 0);"/>

    <Label text="Aggiunta permanentemente al tuo deck per questa run"
           style="-fx-font-size: 15px; -fx-text-fill: #6a6a9a;"/>

    <!-- Le 3 carte vengono generate dinamicamente dal controller -->
    <HBox fx:id="cardsBox" alignment="CENTER" spacing="30"/>

    <Button text="Salta" onAction="#onSkip"
            style="-fx-background-color: transparent; -fx-text-fill: #5a5a7a;
                   -fx-font-size: 13px; -fx-border-color: #3a3a6a; -fx-border-radius: 8;
                   -fx-padding: 8 24; -fx-cursor: hand;"/>

</VBox>
