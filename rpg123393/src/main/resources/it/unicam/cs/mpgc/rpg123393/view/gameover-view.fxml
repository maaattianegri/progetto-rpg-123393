<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="24"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="it.unicam.cs.mpgc.rpg123393.controller.GameOverController"
      style="-fx-background-color: #0d0d1a; -fx-padding: 60;">

    <Label text="☠ GAME OVER ☠"
           style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-text-fill: #e63946;"/>

    <Label fx:id="defeatLabel"
           text="Sei caduto in battaglia..."
           style="-fx-font-size: 18px; -fx-text-fill: #a0a0c0;"
           wrapText="true" textAlignment="CENTER"/>

    <VBox alignment="CENTER" spacing="8"
          style="-fx-background-color: #1a1a2e; -fx-padding: 20; -fx-background-radius: 12;">
        <Label fx:id="levelReachedLabel"
               style="-fx-font-size: 15px; -fx-text-fill: #c77dff;"/>
        <Label fx:id="enemyLabel"
               style="-fx-font-size: 14px; -fx-text-fill: #ff6b6b;"/>
    </VBox>

    <Button text="↺ Ricomincia" onAction="#onRestart"
            prefWidth="240"
            style="-fx-background-color: #e63946; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 12 32; -fx-background-radius: 8; -fx-cursor: hand;"/>

    <Button text="↩ Menu Principale" onAction="#onMainMenu"
            prefWidth="240"
            style="-fx-background-color: transparent; -fx-text-fill: #a0a0c0; -fx-font-size: 13px; -fx-border-color: #a0a0c0; -fx-border-radius: 8; -fx-padding: 8 24; -fx-cursor: hand;"/>

</VBox>
