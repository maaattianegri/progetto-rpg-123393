<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="rootPane" spacing="0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="it.unicam.cs.mpgc.rpg123393.controller.ShopController"
      style="-fx-background-color: transparent; -fx-padding: 0;">

    <!-- Header -->
    <VBox alignment="CENTER" spacing="6" style="-fx-padding: 36 0 10 0;">
        <Label text="&#x1F6D2; Mercante Errante"
               style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #e0c97f;
                      -fx-effect: dropshadow(gaussian, #e0c97f, 16, 0.3, 0, 0);"/>
        <Label text="Acquista saggiamente, avventuriero..."
               style="-fx-font-size: 14px; -fx-text-fill: #c0b080;"/>
        <Label fx:id="goldLabel" text="Oro: 0"
               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #e0c97f;
                      -fx-background-color: rgba(42,32,16,0.80); -fx-padding: 6 20;
                      -fx-background-radius: 16;"/>
    </VBox>

    <!-- Slot shop -->
    <ScrollPane fitToWidth="false" hbarPolicy="AS_NEEDED" vbarPolicy="NEVER"
                VBox.vgrow="ALWAYS"
                style="-fx-background: transparent; -fx-background-color: transparent;
                       -fx-border-color: transparent; -fx-padding: 0;">
        <HBox fx:id="itemsBox" spacing="28" alignment="CENTER"
              style="-fx-background-color: transparent; -fx-padding: 40 60;"/>
    </ScrollPane>

    <!-- Bottone esci -->
    <HBox alignment="CENTER" style="-fx-padding: 16 0 28 0; -fx-background-color: transparent;">
        <Button text="Continua il viaggio" onAction="#onContinue"
                prefWidth="280"
                style="-fx-background-color: #4ecca3; -fx-text-fill: #1a1a2e;
                       -fx-font-size: 16px; -fx-font-weight: bold;
                       -fx-padding: 14 32; -fx-background-radius: 10; -fx-cursor: hand;
                       -fx-effect: dropshadow(gaussian, #4ecca3, 12, 0.3, 0, 0);"/>
    </HBox>

</VBox>
