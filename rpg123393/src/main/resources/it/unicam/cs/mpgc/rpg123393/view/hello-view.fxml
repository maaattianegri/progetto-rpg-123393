<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="it.unicam.cs.mpgc.rpg123393.controller.HelloController"
            style="-fx-background-color: #1a1a2e;">

    <!-- ══════════════════════════════════════════════
         TOP — Pannello Nemico
         ══════════════════════════════════════════════ -->
    <top>
        <VBox alignment="CENTER" spacing="6"
              style="-fx-background-color: #16213e; -fx-padding: 14 20 14 20;
                     -fx-border-color: #e63946; -fx-border-width: 0 0 2 0;">

            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label fx:id="enemyNameLabel" text="Nemico"
                       style="-fx-text-fill: #ff6b6b; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                <Label fx:id="enemyStatsLabel" text="HP: --/--"
                       style="-fx-text-fill: #ffaaaa; -fx-font-size: 13px;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="enemyIntentLabel" text=""
                       style="-fx-text-fill: #ffd166; -fx-font-size: 12px; -fx-font-style: italic;"/>
            </HBox>

            <ProgressBar fx:id="enemyHpBar" progress="1.0" maxWidth="Infinity"
                         style="-fx-accent: #e63946; -fx-pref-height: 12; -fx-background-radius: 6; -fx-pref-width: 9999;"/>

        </VBox>
    </top>

    <!-- ══════════════════════════════════════════════
         CENTER — Immagini combattenti + Log
         ══════════════════════════════════════════════ -->
    <center>
        <HBox alignment="CENTER" spacing="0" style="-fx-background-color: #1a1a2e;">

            <!-- Immagine Player -->
            <VBox alignment="CENTER" minWidth="160" maxWidth="160"
                  style="-fx-padding: 12; -fx-background-color: #12122a;">
                <ImageView fx:id="playerImage"
                           fitWidth="140" fitHeight="140"
                           preserveRatio="true"
                           style="-fx-effect: dropshadow(gaussian, #4ecca3, 10, 0.5, 0, 0);"/>
                <Label fx:id="playerNameCenterLabel" text=""
                       style="-fx-text-fill: #4ecca3; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 4 0 0 0;"
                       VBox.vgrow="NEVER"/>
            </VBox>

            <!-- Log testuale -->
            <TextArea fx:id="consoleArea"
                      editable="false"
                      wrapText="true"
                      style="-fx-control-inner-background: #0d1b2a;
                             -fx-text-fill: #c8d8e8;
                             -fx-font-family: 'Consolas', monospace;
                             -fx-font-size: 12px;
                             -fx-border-color: transparent;
                             -fx-background-color: transparent;"
                      HBox.hgrow="ALWAYS"/>

            <!-- Immagine Nemico -->
            <VBox alignment="CENTER" minWidth="160" maxWidth="160"
                  style="-fx-padding: 12; -fx-background-color: #2a1212;">
                <ImageView fx:id="enemyImage"
                           fitWidth="140" fitHeight="140"
                           preserveRatio="true"
                           style="-fx-effect: dropshadow(gaussian, #e63946, 10, 0.5, 0, 0);"/>
                <Label fx:id="enemyNameCenterLabel" text=""
                       style="-fx-text-fill: #ff6b6b; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 4 0 0 0;"
                       VBox.vgrow="NEVER"/>
            </VBox>

        </HBox>
    </center>

    <!-- ══════════════════════════════════════════════
         BOTTOM — Stats giocatore + Carte + Fine Turno
         ══════════════════════════════════════════════ -->
    <bottom>
        <VBox style="-fx-background-color: #16213e; -fx-border-color: #4ecca3; -fx-border-width: 2 0 0 0;">

            <!-- Riga giocatore: stats + barre (senza immagine, ora è nel center) -->
            <HBox alignment="CENTER_LEFT" spacing="16"
                  style="-fx-padding: 12 20 8 20;">

                <VBox spacing="5" HBox.hgrow="ALWAYS">

                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Label fx:id="playerNameLabel" text="Eroe"
                               style="-fx-text-fill: #4ecca3; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                        <Label fx:id="levelLabel" text="Lv. 1"
                               style="-fx-text-fill: #c77dff; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                        <Label fx:id="playerBlockLabel" text="🛡 0"
                               style="-fx-text-fill: #a0c4ff; -fx-font-size: 13px;"/>
                    </HBox>

                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="HP" style="-fx-text-fill: #4ecca3; -fx-font-size: 11px; -fx-min-width: 32;"/>
                        <ProgressBar fx:id="playerHpBar" progress="1.0"
                                     style="-fx-accent: #4ecca3; -fx-pref-height: 10; -fx-pref-width: 220;"/>
                        <Label fx:id="playerHpLabel" text="--/--"
                               style="-fx-text-fill: #a0d8b3; -fx-font-size: 11px;"/>
                    </HBox>

                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="MP" style="-fx-text-fill: #a78bfa; -fx-font-size: 11px; -fx-min-width: 32;"/>
                        <ProgressBar fx:id="playerManaBar" progress="1.0"
                                     style="-fx-accent: #7c3aed; -fx-pref-height: 10; -fx-pref-width: 220;"/>
                        <Label fx:id="playerManaLabel" text="--/--"
                               style="-fx-text-fill: #c4b5fd; -fx-font-size: 11px;"/>
                    </HBox>

                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="XP" style="-fx-text-fill: #fbbf24; -fx-font-size: 11px; -fx-min-width: 32;"/>
                        <ProgressBar fx:id="playerXpBar" progress="0.0"
                                     style="-fx-accent: #f59e0b; -fx-pref-height: 8; -fx-pref-width: 220;"/>
                        <Label fx:id="playerXpLabel" text="0/100"
                               style="-fx-text-fill: #fde68a; -fx-font-size: 11px;"/>
                    </HBox>

                </VBox>
            </HBox>

            <!-- Carte + Fine Turno -->
            <HBox alignment="CENTER" spacing="14"
                  style="-fx-padding: 0 20 14 20;">

                <Button fx:id="cardBtn0" text="Carta 1" onAction="#onCard0Click"
                        prefWidth="190" prefHeight="260"
                        style="-fx-background-color: #2a2a4a; -fx-text-fill: white;
                               -fx-background-radius: 10; -fx-cursor: hand;
                               -fx-border-color: #444466; -fx-border-radius: 10; -fx-border-width: 1;"/>
                <Button fx:id="cardBtn1" text="Carta 2" onAction="#onCard1Click"
                        prefWidth="190" prefHeight="260"
                        style="-fx-background-color: #2a2a4a; -fx-text-fill: white;
                               -fx-background-radius: 10; -fx-cursor: hand;
                               -fx-border-color: #444466; -fx-border-radius: 10; -fx-border-width: 1;"/>
                <Button fx:id="cardBtn2" text="Carta 3" onAction="#onCard2Click"
                        prefWidth="190" prefHeight="260"
                        style="-fx-background-color: #2a2a4a; -fx-text-fill: white;
                               -fx-background-radius: 10; -fx-cursor: hand;
                               -fx-border-color: #444466; -fx-border-radius: 10; -fx-border-width: 1;"/>

                <VBox alignment="CENTER" spacing="8" style="-fx-padding: 0 0 0 16;">
                    <Button text="Fine Turno &#9654;" onAction="#onEndTurnClick"
                            prefWidth="140"
                            style="-fx-background-color: #e63946; -fx-text-fill: white;
                                   -fx-font-size: 14px; -fx-font-weight: bold;
                                   -fx-padding: 14 20; -fx-background-radius: 8;
                                   -fx-cursor: hand;"/>
                </VBox>

            </HBox>
        </VBox>
    </bottom>

</BorderPane>
